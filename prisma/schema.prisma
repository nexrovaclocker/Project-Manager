generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  member
  intern
}

model User {
  id             String          @id @default(cuid())
  name           String
  username       String          @unique
  passwordHash   String
  role           Role            @default(member)
  status         String?         @default("offline")
  last_seen      DateTime?
  current_task   String?
  createdAt      DateTime        @default(now())
  clockSessions  ClockSession[]
  notes          Note[]
  todoChecks     TodoItem[]      @relation("CheckedBy")
  projectMembers ProjectMember[]
  projectTodos   ProjectTodo[]   @relation("ProjectTodoCreator")
  todoChecksProj ProjectTodo[]   @relation("ProjectTodoChecker")
  dailyLogs      DailyLog[]
  projects       Project[]       @relation("ProjectCreator")
  eventLogs      EventLog[]
}

model ClockSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn         DateTime
  clockOut        DateTime?
  durationMinutes Int?
  sessionNote     String?
  createdAt       DateTime  @default(now())
}

model Note {
  id        String      @id @default(cuid())
  title     String
  createdBy String
  creator   User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  blocks    NoteBlock[]
}

model NoteBlock {
  id        String     @id @default(cuid())
  noteId    String
  note      Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  type      BlockType
  content   String     @default("")
  position  Int
  todoItems TodoItem[]
}

enum BlockType {
  text
  todo
}

model TodoItem {
  id        String    @id @default(cuid())
  blockId   String
  block     NoteBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  text      String
  checked   Boolean   @default(false)
  checkedBy String?
  checker   User?     @relation("CheckedBy", fields: [checkedBy], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String          @default("")
  createdBy   String
  creator     User            @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  members     ProjectMember[]
  todos       ProjectTodo[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectTodo {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text      String
  checked   Boolean  @default(false)
  checkedBy String?
  checker   User?    @relation("ProjectTodoChecker", fields: [checkedBy], references: [id], onDelete: SetNull)
  createdBy String
  creator   User     @relation("ProjectTodoCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model DailyLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String
  detail    String
  timestamp DateTime @default(now())
}
